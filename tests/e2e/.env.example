# E2E Test Environment
# Copy to .env and fill in values

# OpenCode API key (OPTIONAL — free-tier models work without one)
# OPENCODE_API_KEY=oc-your-key-here

# OpenCode API base URL
# OPENCODE_BASE_URL=https://opencode.ai/zen/v1

# Model to use for E2E tests (free models end in -free)
# OPENCODE_MODEL=minimax-m2.5-free

# PiClaw instance URL to test against
PICLAW_E2E_URL=http://localhost:3000

# Internal secret for E2E auth bootstrap
PICLAW_INTERNAL_SECRET=your-instance-secret
