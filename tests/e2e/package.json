{
  "name": "piclaw-e2e",
  "private": true,
  "scripts": {
    "setup": "bun run setup/configure-test-instance.ts",
    "setup:github": "bun run setup/configure-github-models.ts",
    "validate": "bun run setup/validate-test-config.ts",
    "test": "playwright test",
    "test:compose": "playwright test steps/us02-*",
    "test:timeline": "playwright test steps/timeline-*",
    "test:sessions": "playwright test steps/us03-* steps/us09-*",
    "test:settings": "playwright test steps/us06-*",
    "test:editor": "playwright test steps/us04-*",
    "test:mobile": "playwright test --project=ipad --project=iphone",
    "test:reconnect": "playwright test steps/us07-*",
    "test:smoke": "playwright test steps/us01-*",
    "report": "bun run scripts/generate-report.ts",
    "report:html": "playwright show-report reports/html"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@cucumber/cucumber": "^11.0.0",
    "playwright-bdd": "^7.0.0"
  }
}
