{
  "id": "codemirror-highlight",
  "packageName": "@lezer/highlight",
  "sourceEntry": "web/src/vendor/codemirror-highlight-entry.ts",
  "outputFile": "web/static/js/vendor/codemirror-highlight.min.js",
  "metadataFile": "web/static/js/vendor/codemirror-highlight.meta.json",
  "buildCommand": [
    "bun",
    "build",
    "$SOURCE_ENTRY",
    "--target=browser",
    "--format=iife",
    "--minify",
    "--outfile",
    "$OUTPUT_FILE"
  ]
}
