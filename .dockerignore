# Include the skeleton
!skel/
!skel/**

# Include runtime subtree and root packaging/docs files needed by Docker
!runtime/
!runtime/**
!README.md
!LICENSE
!package.json
!bun.lock
!docs/install-from-repo.md

# Note: runtime/web/src/ (upstream piclaw UI) is kept in Docker context
# because vendor builds, login, styles, and editor extension reference files in it.
# The piclaw-monaco frontend (runtime/web/frontend/) replaces it for app.bundle.js.

# Keep the repo-local kanban board out of Docker build context
kanban/
